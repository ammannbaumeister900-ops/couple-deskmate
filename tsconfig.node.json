{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "electron-dist"
  },
  "include": ["vite.config.ts", "electron/**/*.ts", "src/appActions.ts", "src/demoState.ts"]
}
